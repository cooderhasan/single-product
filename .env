# Database
DB_USER=postgres
DB_PASSWORD=123456
DB_NAME=sehpa
DATABASE_URL="postgresql://postgres:123456@localhost:5432/sehpa?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your_super_secret_jwt_key_change_this_in_production"
JWT_EXPIRES_IN="7d"

# API
API_PORT=3041
API_URL="http://localhost:3041"

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:3041"
NEXT_PUBLIC_SITE_URL="http://localhost:3040"
NEXT_PUBLIC_ADMIN_URL="http://localhost:3042"

# PayTR Payment
PAYTR_MERCHANT_ID="your_paytr_merchant_id"
PAYTR_MERCHANT_KEY="your_paytr_merchant_key"
PAYTR_MERCHANT_SALT="your_paytr_merchant_salt"
PAYTR_TEST_MODE="1"

# Admin
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="admin123"

# Email (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your_email@gmail.com"
SMTP_PASSWORD="your_app_password"

# Cloudinary (Image Upload)
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Analytics
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
NEXT_PUBLIC_FB_PIXEL_ID="XXXXXXXXXX"

# WhatsApp
NEXT_PUBLIC_WHATSAPP_NUMBER="905XXXXXXXXX"

# XML Feed
XML_FEED_TOKEN="your_secure_xml_token"
